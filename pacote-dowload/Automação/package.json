{
  "name": "barber-bot",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "build": "tsc -p .",
    "start": "node dist/index.js",
    "start:prod": "npm run setup:cliente && node dist/index.js",
    "postinstall": "prisma generate",
    "db:deploy": "prisma migrate deploy",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "setup:cliente": "node scripts/bootstrap-cliente.js",
    "simular:agendamento": "powershell -ExecutionPolicy Bypass -File ./scripts/simular-agendamento.ps1"
  },
  "dependencies": {
    "@prisma/client": "^5.6.0",
    "axios": "^1.6.6",
    "body-parser": "^1.20.2",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "helmet": "^8.1.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^25.9.3",
    "@types/supertest": "^7.2.0",
    "@vitest/coverage-v8": "^3.2.4",
    "prisma": "^5.6.0",
    "supertest": "^7.2.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.2.2",
    "vitest": "^3.2.4"
  }
}
