# Exemplo de variáveis de ambiente
DATABASE_URL="file:./prisma/dev.db"
# Token e phone id da Meta Business API (preencha após configurar)
META_ACCESS_TOKEN=
META_PHONE_NUMBER_ID=
# Verificação de webhook usada pela Meta para validar o endpoint
WEBHOOK_VERIFY_TOKEN=meu_token_secreto
# URL pública onde seu servidor receberá webhooks (ngrok ou deploy)
WEBHOOK_URL=
